# =============================================================================
# Beispiel-Konfiguration. Kopieren nach .env und Werte anpassen.
# In Produktion (Render) stattdessen als Environment Variables setzen.
# JWT-Secrets neu erzeugen mit:  openssl rand -hex 32
# =============================================================================

DATABASE_URL=file:./prisma/dev.db
PORT=4000
NODE_ENV=development

# JWT — für jedes Deployment eigene Secrets erzeugen.
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# CORS — nur relevant, wenn das Frontend von einer ANDEREN Origin geladen wird.
# Im Ein-Prozess-Betrieb (Backend liefert das Frontend selbst aus) unnötig.
CORS_ORIGINS=http://127.0.0.1:8200

# Demo-Reservierungen beim Seed anlegen? Im echten Betrieb auf false setzen.
SEED_DEMO=false

# Erst-Admin & Service-Konto (beim ersten Seed angelegt). Passwörter danach ändern!
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
SEED_STAFF_EMAIL=staff@example.com
SEED_STAFF_PASSWORD=change-me

# -----------------------------------------------------------------------------
# E-Mail-Versand (SMTP) — optional.
# Ohne SMTP_HOST ist der Versand inaktiv; Buchungen funktionieren trotzdem.
# Funktioniert mit jedem Anbieter (IONOS, Strato, Gmail, Mailgun, Resend-SMTP …).
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.ionos.de
# SMTP_PORT=587                 # 587 = STARTTLS, 465 = SSL
# SMTP_SECURE=false             # true NUR bei Port 465
# SMTP_USER=reservierung@dein-restaurant.de
# SMTP_PASS=dein-postfach-passwort
# MAIL_FROM=Lumière <reservierung@dein-restaurant.de>   # fällt sonst auf SMTP_USER zurück
# RESTAURANT_NOTIFY_EMAIL=info@dein-restaurant.de        # Benachrichtigung ans Restaurant (leer = keine)
# RESTAURANT_NAME=Lumière
# MAIL_ENABLED=true             # auf false setzen, um den Versand temporär zu deaktivieren
